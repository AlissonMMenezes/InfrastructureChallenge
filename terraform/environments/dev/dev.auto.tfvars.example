ssh_public_key = ""

object_storage_enabled = true

object_storage_region = "fsn1"

# Leave empty to use the default endpoint host: "{object_storage_region}.your-objectstorage.com"
object_storage_endpoint = ""

object_storage_access_key = ""
object_storage_secret_key = ""

# Globally unique bucket name. Leave empty to use "{cluster_name}-cnpg-backups" (cluster_name defaults to dev-test in variables.tf unless overridden).
object_storage_bucket_name = ""
